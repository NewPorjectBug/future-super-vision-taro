{
  "name": "future-super-vision-taro-complete",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:test": "set API_ENV=test&& set VITE_API_ENV=test&& npm run build:h5",
    "build:prod": "set API_ENV=production&& set VITE_API_ENV=production&& npm run build:h5"
  },
  "dependencies": {
    "@tarojs/components": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/vite-runner": "4.1.11",
    "@tarojs/webpack5-runner": "^4.1.11",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@vitejs/plugin-react": "4.3.4",
    "react-refresh": "^0.18.0",
    "sass": "1.77.6",
    "typescript": "5.4.5",
    "vite": "4.5.14"
  },
  "engines": {
    "node": ">=18"
  }
}
